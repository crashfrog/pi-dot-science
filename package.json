{
  "name": "pi.science",
  "version": "0.1.0",
  "description": "A terminal-based data science agent for exploratory analysis",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pi-sci": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run index.ts",
    "build": "bun build --compile --target=bun --outfile=pi-sci index.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
